// =============================================================================
// ONE SCRIPT → MAIN CHART + SEPARATE PANE (TradingView)
// =============================================================================
// Topic: "Display visuals on the chart from your pane scripts" — force_overlay
// https://www.tradingview.com/blog/en/display-visuals-on-chart-from-pane-scripts-45290/
//
// How it works:
//   1. overlay = false  → TradingView creates ONE indicator pane (separate section).
//   2. plot() without force_overlay → draws ONLY in that pane (CVD lives here).
//   3. line.new / box.new with force_overlay = true → draw on MAIN price chart
//      (volume profile + S/R levels).
//
// CVD logic: cumulative_volume_delta.pine (Ankit_1618, MPL-2.0).
// S/R logic: supportresistance.pine
// Longer write-up: docs/indicators-pine/pine-pane-and-main-chart.md
// =============================================================================

//@version=6
indicator("S/R (main) + CVD (pane)", shorttitle = "S/R+CVD", overlay = false, scale = scale.right, max_bars_back = 5000, max_lines_count = 500, max_boxes_count = 500)

// -----------------------------------------------------------------------------
// INPUT GROUPS  (main chart = force_overlay | pane = plot() only — see .md in repo)
// -----------------------------------------------------------------------------
grp_sr = "Main chart — Support / Resistance + vol profile"
grp_cvd = "Pane only — Cumulative volume delta"

bars_back = input.int(2000, minval = 100, maxval = 5000, title = "Horizon", group = grp_sr)
N = input.int(500, minval = 10, maxval = 500, title = "Number of Baskets", group = grp_sr)
M = input.int(9, minval = 1, maxval = 50, title = "Vicinity for minima", group = grp_sr)
W = input.int(8, minval = 1, maxval = 50, title = "Smoothing window", group = grp_sr)
width_multiplier = input.float(1.0, minval = 0.01, maxval = 10.0, title = "Line width mult.", group = grp_sr)
max_width = input.float(10.0, minval = 0.1, maxval = 20.0, title = "Line max width", group = grp_sr)
show_vol_profile = input.bool(true, title = "Volume profile on main chart", group = grp_sr)
lines_color = input.color(color.rgb(51, 33, 243, 61), title = "S/R line color", group = grp_sr)
boxes_color = input.color(#00e5ce7d, title = "Profile box color", group = grp_sr)
show_sr = input.bool(true, title = "Enable main-chart S/R + profile", group = grp_sr)

cumulation_length = input.int(14, minval = 1, title = "CVD EMA length", group = grp_cvd)
show_cvd = input.bool(true, title = "Enable CVD in this pane", group = grp_cvd)

// -----------------------------------------------------------------------------
// S/R smoothing
// -----------------------------------------------------------------------------
smooth_triangular(input_array, window_size) =>
    smoothed_array = array.new_float(N, 0.0)
    actual_window_size = window_size % 2 == 0 ? window_size + 1 : window_size
    actual_window_size := math.max(actual_window_size, 3)
    half_window = int(actual_window_size / 2)
    weights = array.new_float(actual_window_size, 0.0)
    weight_sum = 0.0
    for j = 0 to actual_window_size - 1
        distance_from_center = math.abs(j - half_window)
        weight = half_window + 1 - distance_from_center
        array.set(weights, j, weight)
        weight_sum := weight_sum + weight
    for j = 0 to actual_window_size - 1
        array.set(weights, j, array.get(weights, j) / weight_sum)
    for i = 0 to N - 1
        smoothed_value = 0.0
        for j = 0 to actual_window_size - 1
            array_index = i + j - half_window
            weight = array.get(weights, j)
            if array_index < 0
                smoothed_value := smoothed_value + array.get(input_array, 0) * weight
            else if array_index >= N
                smoothed_value := smoothed_value + array.get(input_array, N - 1) * weight
            else
                smoothed_value := smoothed_value + array.get(input_array, array_index) * weight
        array.set(smoothed_array, i, smoothed_value)
    smoothed_array

// =============================================================================
// PANE ONLY — Cumulative Volume Delta (no force_overlay on any plot here)
// =============================================================================
upper_wick = close > open ? high - close : high - open
lower_wick = close > open ? open - low : close - low
spread = high - low
body_length = spread - (upper_wick + lower_wick)
pct_u = spread > 0 ? upper_wick / spread : 0.0
pct_l = spread > 0 ? lower_wick / spread : 0.0
pct_b = spread > 0 ? body_length / spread : 0.0
buying_volume = close > open ? (pct_b + (pct_u + pct_l) / 2.0) * volume : ((pct_u + pct_l) / 2.0) * volume
selling_volume = close < open ? (pct_b + (pct_u + pct_l) / 2.0) * volume : ((pct_u + pct_l) / 2.0) * volume
cumulative_buying_volume = ta.ema(buying_volume, cumulation_length)
cumulative_selling_volume = ta.ema(selling_volume, cumulation_length)
fill_color_cvd = cumulative_buying_volume > cumulative_selling_volume ? color.green : cumulative_buying_volume < cumulative_selling_volume ? color.red : color.yellow
volume_strength_wave = cumulative_buying_volume > cumulative_selling_volume ? cumulative_buying_volume : cumulative_selling_volume
ema_volume_strength_wave = ta.ema(volume_strength_wave, cumulation_length)
cumulative_volume_delta = cumulative_buying_volume - cumulative_selling_volume

// Zero reference for delta columns (pane only)
hline(show_cvd ? 0 : na, "Delta zero", color = color.new(color.gray, 50), linestyle = hline.style_dotted)

pb = plot(show_cvd ? cumulative_buying_volume : na, "CVD Buy vol", color = color.new(color.green, 70))
ps = plot(show_cvd ? cumulative_selling_volume : na, "CVD Sell vol", color = color.new(color.red, 70))
fill(pb, ps, color = show_cvd ? fill_color_cvd : na)
plot(show_cvd ? ema_volume_strength_wave : na, "CVD Strength EMA", color = color.new(color.gray, 80))
plot(show_cvd ? cumulative_volume_delta : na, "CVD Delta", color = cumulative_volume_delta > 0 ? color.new(color.green, 61) : color.new(color.red, 61), style = plot.style_columns)

// =============================================================================
// MAIN CHART ONLY — force_overlay on every drawing (vol profile + S/R lines)
// =============================================================================
min_price = ta.lowest(low, bars_back)
max_price = ta.highest(high, bars_back)

if barstate.islast and show_sr
    var float[] volume_baskets = array.new_float(N, 0.0)
    var box[] histogram_boxes = array.new_box(N)
    var line[] minima_lines = array.new_line(N)
    for idx = 0 to N - 1
        array.set(volume_baskets, idx, 0.0)
    // Recency weighting (same idea as Python build_volume_profile_from_candles):
    // Python: weight = (window_size - position_from_newest) / window_size  → newest 1, oldest 1/window_size
    // Pine i=0 is newest; i=bars_back is oldest. Match Python scale: vol * (bars_back - i + 1) / (bars_back + 1)
    denom_bars = float(bars_back + 1)
    for i = 0 to bars_back
        avg_price = (high[i] + low[i]) / 2
        denom = max_price - min_price
        basket_index = denom != 0 ? int(math.floor((avg_price - min_price) / denom * (N - 1))) : 0
        recency_w = (bars_back - i + 1) / denom_bars
        if basket_index >= 0 and basket_index < N
            array.set(volume_baskets, basket_index, array.get(volume_baskets, basket_index) + volume[i] * recency_w)
    var line min_price_line = na
    var line max_price_line = na
    smoothed_baskets = smooth_triangular(volume_baskets, W)
    for i = 0 to array.size(histogram_boxes) - 1
        box.delete(array.get(histogram_boxes, i))
    array.clear(histogram_boxes)
    for i = 0 to array.size(minima_lines) - 1
        line.delete(array.get(minima_lines, i))
    array.clear(minima_lines)
    max_volume = 0.0
    for i = 0 to N - 1
        max_volume := math.max(max_volume, array.get(smoothed_baskets, i))
    for i = 0 to N - 1
        vol = array.get(smoothed_baskets, i)
        vol_norm = max_volume > 0 ? vol / max_volume : 0.0
        basket_price_low = min_price + i * (max_price - min_price) / N
        basket_price_high = min_price + (i + 1) * (max_price - min_price) / N
        x_right = bar_index + 1 + 50
        histogram_width = math.max(int(vol_norm * 50), 1)
        x_left = x_right - histogram_width
        top_left = chart.point.from_index(x_right, basket_price_high)
        bottom_right = chart.point.from_index(x_left, basket_price_low)
        if show_vol_profile
            array.push(histogram_boxes, box.new(top_left, bottom_right, xloc = xloc.bar_index, bgcolor = boxes_color, border_width = 0, force_overlay = true))
    var int[] minima_indices = array.new_int(0)
    var float[] minima_volumes = array.new_float(0)
    array.clear(minima_indices)
    array.clear(minima_volumes)
    for i = M to N - M - 1
        vol_curr = array.get(smoothed_baskets, i)
        is_min = true
        for j = i - M to i + M
            if j != i and array.get(smoothed_baskets, j) <= vol_curr
                is_min := false
                break
        if is_min
            array.push(minima_indices, i)
            array.push(minima_volumes, vol_curr)
    if array.size(minima_indices) > 0
        for k = 0 to array.size(minima_indices) - 1
            minima_index = array.get(minima_indices, k)
            minima_volume = array.get(minima_volumes, k)
            left_start = k > 0 ? array.get(minima_indices, k - 1) + 1 : 0
            left_cluster_sum = 0.0
            left_cluster_size = 0
            for j = left_start to minima_index - 1
                left_cluster_sum := left_cluster_sum + array.get(smoothed_baskets, j)
                left_cluster_size := left_cluster_size + 1
            right_end = k < array.size(minima_indices) - 1 ? array.get(minima_indices, k + 1) - 1 : N - 1
            right_cluster_sum = 0.0
            right_cluster_size = 0
            for j = minima_index + 1 to right_end
                right_cluster_sum := right_cluster_sum + array.get(smoothed_baskets, j)
                right_cluster_size := right_cluster_size + 1
            total_cluster_size = left_cluster_size + right_cluster_size
            clusters_average = total_cluster_size > 0 ? (left_cluster_sum + right_cluster_sum) / total_cluster_size : minima_volume
            volume_ratio = clusters_average > 0 ? clusters_average / minima_volume : 1.0
            line_width_int = int(math.min(math.max(1, volume_ratio * width_multiplier), max_width))
            basket_price = min_price + (minima_index + 0.5) * (max_price - min_price) / N
            array.push(minima_lines, line.new(bar_index, basket_price, bar_index + 1, basket_price, xloc = xloc.bar_index, extend = extend.both, color = lines_color, width = line_width_int, style = line.style_solid, force_overlay = true))
    if not na(min_price_line)
        line.delete(min_price_line)
    if not na(max_price_line)
        line.delete(max_price_line)
    min_price_line := line.new(bar_index, min_price, bar_index + 1, min_price, xloc = xloc.bar_index, extend = extend.both, color = lines_color, width = 1, style = line.style_dashed, force_overlay = true)
    max_price_line := line.new(bar_index, max_price, bar_index + 1, max_price, xloc = xloc.bar_index, extend = extend.both, color = lines_color, width = 1, style = line.style_dashed, force_overlay = true)
